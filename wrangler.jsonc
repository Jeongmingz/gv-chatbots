{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gv-chatbots",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-07",
  "assets": {
    "directory": "./public",
    "run_worker_first": ["/health", "/faq/*", "/skill/*"]
  },
  "observability": {
    "enabled": true
  }
}
